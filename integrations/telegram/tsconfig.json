{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["definitions/**/*", "bp_modules/**/*", "src/**/*", "test/**/*", "tests/**/*", "*.ts"],
  "exclude": ["node_modules", ".botpress", "dist"]
}

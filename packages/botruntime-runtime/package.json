{
  "name": "@holocronlab/botruntime-runtime",
  "version": "2.0.2",
  "description": "Lightweight runtime library for ADK-based botruntime agents",
  "keywords": [
    "adk",
    "agent",
    "ai",
    "chatbot",
    "conversational-ai",
    "runtime"
  ],
  "license": "MIT",
  "author": "HolocronLab",
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-runtime"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "readme.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    },
    "./library": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./definition": {
      "types": "./dist/definition.d.ts",
      "import": "./dist/definition.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    },
    "./_types/*": {
      "types": "./dist/_types/*.d.ts"
    }
  },
  "scripts": {
    "build": "bun esbuild.ts && tsc -p tsconfig.build.json",
    "build:watch": "bun esbuild.ts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build",
    "check:type": "tsc --noEmit"
  },
  "dependencies": {
    "@holocronlab/botruntime-chat": "file:../botruntime-chat",
    "@holocronlab/botruntime-client": "file:../botruntime-client",
    "@holocronlab/botruntime-cognitive": "file:../botruntime-cognitive",
    "@holocronlab/botruntime-const": "file:../botruntime-const",
    "@holocronlab/botruntime-evals": "file:../botruntime-evals",
    "@holocronlab/botruntime-llmz": "file:../botruntime-llmz",
    "@holocronlab/botruntime-sdk": "file:../botruntime-sdk",
    "@holocronlab/botruntime-thicktoken": "file:../botruntime-thicktoken",
    "@holocronlab/botruntime-zai": "file:../botruntime-zai",
    "@holocronlab/botruntime-zui": "file:../botruntime-zui",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "axios": "^1.13.2",
    "bytes": "^3.1.2",
    "dedent": "^1.7.1",
    "fast-safe-stringify": "^2.1.1",
    "fast-xml-parser": "^5.3.3",
    "glob": "^11.1.0",
    "lodash": "^4.17.21",
    "ms": "^2.1.3",
    "object-sizeof": "^2.6.5",
    "p-limit": "^7.3.0",
    "pretty-bytes": "^7.0.1",
    "ulid": "^3.0.2",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.5",
    "@types/lodash": "^4.17.13",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.16.4",
    "@types/react": ">=18",
    "bun-types": "1.3.14",
    "esbuild": "^0.25.10",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@types/react": ">=18",
    "typescript": ">=4.5.0"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.14"
}

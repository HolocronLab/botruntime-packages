{
  "name": "@holocronlab/botruntime-jex",
  "description": "JSON-Extends; JSON Schema type checking library",
  "version": "1.2.4",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "check:type": "tsc --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.2",
    "@types/json-schema": "^7.0.15",
    "lodash": "^4.17.21",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "^22.16.4",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-jex"
  },
  "author": "HolocronLab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "name": "@holocronlab/botruntime-zai",
  "description": "Zui AI (zai) - an LLM utility library written on top of Zui and the botruntime Cognitive client",
  "version": "2.8.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "check:type": "tsc --noEmit",
    "build:type": "rollup -c rollup.dts.config.mjs && node ./scripts/flatten-augmentations.mjs",
    "build:neutral": "ts-node -T ./build.ts --neutral",
    "build": "ts-node -T ./build.ts --neutral && rollup -c rollup.dts.config.mjs && node ./scripts/flatten-augmentations.mjs"
  },
  "keywords": [],
  "author": "HolocronLab",
  "license": "ISC",
  "dependencies": {
    "@holocronlab/botruntime-cognitive": "file:../botruntime-cognitive",
    "@holocronlab/botruntime-thicktoken": "file:../botruntime-thicktoken",
    "@holocronlab/botruntime-zui": "file:../botruntime-zui",
    "json5": "^2.2.3",
    "jsonrepair": "^3.10.0",
    "lodash-es": "^4.17.21",
    "p-limit": "^7.2.0"
  },
  "devDependencies": {
    "@holocronlab/botruntime-client": "file:../botruntime-client",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.4",
    "esbuild": "^0.25.10",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-zai"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.0"
}

    "@babel/standalone": "7.26.4",
    "@babel/traverse": "7.26.9",
    "@babel/types": "7.26.9",
    "@holocronlab/botruntime-client": "file:../botruntime-client",
    "@holocronlab/botruntime-cognitive": "file:../botruntime-cognitive",
    "@holocronlab/botruntime-thicktoken": "file:../botruntime-thicktoken",
    "@holocronlab/botruntime-zui": "file:../botruntime-zui",
    "@jitl/quickjs-singlefile-browser-release-sync": "^0.31.0",
    "bytes": "^3.1.2",
    "exponential-backoff": "^3.1.1",
    "handlebars": "^4.7.8",
    "lodash-es": "^4.17.21",
    "lru-cache": "~11.0.2",
    "ms": "^2.1.3",
    "prettier": "^3.4.2",
    "quickjs-emscripten-core": "^0.31.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",

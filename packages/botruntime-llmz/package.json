    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-llmz"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --noCheck",
    "check:type": "tsc --noEmit",
    "watch": "tsup --watch",
    "test": "vitest --run"
  },
  "keywords": [],
  "author": "HolocronLab",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "7.26.9",

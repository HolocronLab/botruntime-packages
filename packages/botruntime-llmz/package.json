{
  "name": "@holocronlab/botruntime-llmz",
  "type": "module",
  "description": "An LLM-native Typescript VM built on top of botruntime Zui - code-generation agent framework",
  "version": "0.0.84",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },

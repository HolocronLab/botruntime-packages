{
  "name": "@holocronlab/brt",
  "version": "0.5.7",
  "private": false,
  "description": "brt — botruntime CLI. Full fork of @botpress/cli (MIT), rebranded and repointed at our cloudapi (botruntime.ru). Keeps the native build (codegen + esbuild bundle), local dev/serve, and the cloud deploy/login flow against our host.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "brt": "src/cli.ts"
  },
  "files": [
    "src",
    "templates",
    "brt-docs-contract.json",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages.git",
    "directory": "packages/brt"
  },
  "scripts": {
    "brt": "bun src/cli.ts",
    "docs:contract:check": "bun src/generate-docs-contract.ts --check",
    "docs:contract:generate": "bun src/generate-docs-contract.ts",
    "docs:contract:test": "vitest --run src/docs-contract.test.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.0",
    "@holocronlab/botruntime-adk": "file:../botruntime-adk",
    "@holocronlab/botruntime-chat": "file:../botruntime-chat",
    "@holocronlab/botruntime-client": "file:../botruntime-client",
    "@holocronlab/botruntime-sdk": "file:../botruntime-sdk",
    "@holocronlab/botruntime-const": "file:../botruntime-const",
    "@holocronlab/botruntime-tunnel": "file:../botruntime-tunnel",
    "@holocronlab/botruntime-verel": "file:../botruntime-verel",
    "@holocronlab/botruntime-yargs-extra": "file:../botruntime-yargs-extra",
    "@holocronlab/botruntime-zui": "file:../botruntime-zui",
    "@parcel/watcher": "^2.1.0",
    "@stoplight/spectral-core": "^1.19.1",
    "@stoplight/spectral-functions": "^1.9.0",
    "@stoplight/spectral-parsers": "^1.0.4",
    "@stoplight/types": "^14.1.1",
    "@types/lodash": "^4.14.191",
    "@types/verror": "^1.10.6",
    "axios": "^1.4.0",
    "bluebird": "^3.7.2",
    "boxen": "5.1.2",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.4",
    "esbuild": "^0.25.10",
    "handlebars": "^4.7.8",
    "jsonpath-plus": "^10.3.0",
    "latest-version": "5.1.0",
    "lodash": "^4.17.21",
    "prettier": "^3.4.2",
    "prompts": "^2.4.2",
    "semver": "^7.3.8",
    "uuid": "^9.0.0",
    "verror": "^1.10.1",
    "yn": "^4.0.0"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.38",
    "@types/ini": "^4.1.1",
    "@types/json-schema": "^7.0.12",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.0.14",
    "@types/semver": "^7.3.11",
    "@types/tmp": "^0.2.3",
    "@types/uuid": "^9.0.1",
    "find-process": "^2.0.0",
    "glob": "^9.3.4",
    "tmp": "^0.2.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}

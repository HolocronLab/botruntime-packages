{
  "name": "@holocronlab/botruntime-adk",
  "description": "Core ADK library for building AI agents on botruntime.",
  "version": "2.1.17",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dependencies": {
      "types": "./dist/dependencies/index.d.ts",
      "import": "./dist/dependencies/index.js"
    },
    "./internal/agent0": {
      "types": "./dist/agent0/index.d.ts",
      "import": "./dist/agent0/index.js"
    },
    "./internal/bp-cli": {
      "types": "./dist/commands/bp-cli.d.ts",
      "import": "./dist/commands/bp-cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "bun run clean && bun run build:types && bun run build:chat-bundle && bun run build:js",
    "build:types": "tsc --emitDeclarationOnly",
    "build:chat-bundle": "bun run scripts/build-chat-bundle.ts",
    "build:js": "bun run scripts/build.ts",
    "clean": "rm -rf dist",
    "check:type": "tsc --noEmit",
    "test": "vitest --run",
    "prepublishOnly": "node -e \"['dist/index.js','dist/dependencies/index.js','dist/agent0/index.js','dist/commands/bp-cli.js'].forEach(f=>{if(!require('fs').existsSync(f)){console.error('FATAL: '+f+' missing — types-only build; run: bun run build:js');process.exit(1)}})\""
  },
  "dependencies": {
    "@holocronlab/botruntime-sdk": "file:../botruntime-sdk",
    "@holocronlab/botruntime-client": "file:../botruntime-client",
    "@holocronlab/botruntime-chat": "file:../botruntime-chat",
    "@holocronlab/botruntime-cognitive": "file:../botruntime-cognitive",
    "@holocronlab/botruntime-runtime": "file:../botruntime-runtime",
    "@holocronlab/botruntime-zui": "file:../botruntime-zui",
    "@holocronlab/botruntime-jex": "file:../botruntime-jex",
    "@holocronlab/botruntime-analytics": "file:../botruntime-analytics",
    "@parcel/watcher": "^2.5.1",
    "debug": "^4.4.3",
    "dedent": "^1.7.1",
    "execa": "9.6.1",
    "glob": "^11.1.0",
    "luxon": "^3.7.2",
    "opencode-ai": "1.15.10",
    "oxfmt": "^0.41.0",
    "semver": "^7.7.2",
    "tree-kill": "^1.2.2",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.16.4",
    "@types/semver": "^7.5.8",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-adk"
  },
  "author": "HolocronLab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}

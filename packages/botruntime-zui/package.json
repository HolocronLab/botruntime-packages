{
  "name": "@holocronlab/botruntime-zui",
  "version": "2.3.1",
  "description": "A fork of Zod with additional features",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "check:type": "tsc --noEmit",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.12",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.4",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "local-ref-resolver": "^0.2.0",
    "lodash-es": "^4.17.21",
    "prettier": "^3.4.2",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HolocronLab/botruntime-packages",
    "directory": "packages/botruntime-zui"
  },
  "author": "HolocronLab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
